{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/hedera/refs/heads/main/json-schema/EvmAddressWithShardRealm.json",
  "title": "EvmAddressWithShardRealm",
  "type": "string",
  "description": "A network entity encoded as an EVM address in hex.",
  "format": "binary",
  "minLength": 40,
  "maxLength": 60,
  "pattern": "^(\\d{1,10}\\.){0,2}[A-Fa-f0-9]{40}$",
  "example": "0x0000000000000000000000000000000000001f41"
}